<section>
  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-teal-700">Admin workflow</p>
      <h1 class="mt-2 text-3xl font-bold">Request dashboard</h1>
    </div>
  </div>

  <%= form_with url: admin_issues_path, method: :get, local: true, class: "mt-6 grid gap-4 rounded-lg border border-slate-200 bg-white p-4 md:grid-cols-4" do |form| %>
    <div>
      <%= form.label :query, "Search", class: "block text-sm font-medium text-slate-700" %>
      <%= form.search_field :query, value: params[:query], class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :status, class: "block text-sm font-medium text-slate-700" %>
      <%= form.select :status, [["All", ""]] + @statuses.map { |status| [Issue.new(status: status).status_label, status] }, { selected: params[:status] }, class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :category, class: "block text-sm font-medium text-slate-700" %>
      <%= form.select :category, [["All", ""]] + @categories.map { |category| [category.humanize.titleize, category] }, { selected: params[:category] }, class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2" %>
    </div>
    <div class="flex items-end">
      <%= form.submit "Apply filters", class: "w-full rounded-md bg-slate-900 px-4 py-2 font-semibold text-white hover:bg-slate-700" %>
    </div>
  <% end %>

  <% if @issues.empty? %>
    <div class="mt-8 rounded-lg border border-dashed border-slate-300 bg-white p-8 text-center text-slate-600">No requests match the current filters.</div>
  <% else %>
    <div class="mt-8 grid gap-4 lg:grid-cols-4">
      <% @statuses.each do |status| %>
        <section class="rounded-lg border border-slate-200 bg-white">
          <h2 class="border-b border-slate-200 px-4 py-3 text-sm font-semibold text-slate-800"><%= Issue.new(status: status).status_label %></h2>
          <div class="space-y-3 p-3">
            <% (@issues_by_status[status] || []).each do |issue| %>
              <%= link_to admin_issue_path(issue), class: "block rounded-md border border-slate-200 p-4 hover:border-teal-600 hover:bg-teal-50" do %>
                <h3 class="font-semibold text-slate-950"><%= issue.title %></h3>
                <p class="mt-2 text-sm text-slate-600"><%= issue.location %></p>
                <div class="mt-3 flex flex-wrap gap-2 text-xs font-medium">
                  <span class="rounded bg-slate-100 px-2 py-1 text-slate-700"><%= issue.category_label %></span>
                  <span class="rounded bg-amber-100 px-2 py-1 text-amber-900"><%= issue.priority.humanize %></span>
                </div>
              <% end %>
            <% end %>
          </div>
        </section>
      <% end %>
    </div>
  <% end %>
</section>
