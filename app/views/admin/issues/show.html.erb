<section class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_24rem]">
  <article class="rounded-lg border border-slate-200 bg-white p-6">
    <%= link_to "Back to dashboard", admin_issues_path, class: "text-sm font-medium text-teal-700 hover:text-teal-900" %>
    <h1 class="mt-4 text-3xl font-bold"><%= @issue.title %></h1>
    <p class="mt-3 whitespace-pre-line text-slate-700"><%= @issue.description %></p>

    <% if @issue.image.attached? %>
      <div class="mt-6">
        <h2 class="text-sm font-semibold text-slate-700">Uploaded image</h2>
        <%= image_tag @issue.image, class: "mt-2 max-h-96 rounded-lg border border-slate-200 object-contain" %>
      </div>
    <% end %>

    <div class="mt-6 rounded-lg border border-teal-200 bg-teal-50 p-4">
      <h2 class="font-semibold text-teal-950">AI assisted triage</h2>
      <dl class="mt-3 grid gap-3 text-sm sm:grid-cols-3">
        <div>
          <dt class="font-medium text-teal-800">Summary</dt>
          <dd class="mt-1 text-teal-950"><%= @issue.ai_summary %></dd>
        </div>
        <div>
          <dt class="font-medium text-teal-800">Suggested category</dt>
          <dd class="mt-1 text-teal-950"><%= @issue.ai_suggested_category %></dd>
        </div>
        <div>
          <dt class="font-medium text-teal-800">Priority</dt>
          <dd class="mt-1 text-teal-950"><%= @issue.priority.humanize %></dd>
        </div>
      </dl>
    </div>

    <section class="mt-8">
      <h2 class="text-lg font-semibold">Internal notes</h2>
      <div class="mt-4 space-y-3">
        <% @issue.comments.order(created_at: :desc).each do |comment| %>
          <div class="rounded-md border border-slate-200 p-4">
            <p class="text-sm text-slate-500"><%= comment.user.email %> · <%= l(comment.created_at, format: :short) %></p>
            <p class="mt-2 whitespace-pre-line text-slate-800"><%= comment.body %></p>
          </div>
        <% end %>
      </div>

      <%= form_with model: [:admin, @comment], local: true, class: "mt-4 space-y-3" do |form| %>
        <%= form.hidden_field :issue_id, value: @issue.id %>
        <%= form.label :body, "Add internal note", class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_area :body, rows: 4, required: true, class: "w-full rounded-md border border-slate-300 px-3 py-2" %>
        <%= form.submit "Add note", class: "rounded-md bg-slate-900 px-4 py-2 font-semibold text-white hover:bg-slate-700" %>
      <% end %>
    </section>
  </article>

  <aside class="h-fit rounded-lg border border-slate-200 bg-white p-6">
    <h2 class="text-lg font-semibold">Manage request</h2>
    <%= form_with model: [:admin, @issue], local: true, method: :patch, class: "mt-4 space-y-4" do |form| %>
      <div>
        <%= form.label :status, class: "block text-sm font-medium text-slate-700" %>
        <%= form.select :status, Issue.statuses.keys.map { |status| [Issue.new(status: status).status_label, status] }, {}, class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2" %>
      </div>
      <div>
        <%= form.label :category, class: "block text-sm font-medium text-slate-700" %>
        <%= form.select :category, Issue.categories.keys.map { |category| [category.humanize.titleize, category] }, {}, class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2" %>
      </div>
      <div>
        <%= form.label :priority, class: "block text-sm font-medium text-slate-700" %>
        <%= form.select :priority, Issue.priorities.keys.map { |priority| [priority.humanize, priority] }, {}, class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2" %>
      </div>
      <div>
        <%= form.label :assigned_to_id, "Assigned to", class: "block text-sm font-medium text-slate-700" %>
        <%= form.collection_select :assigned_to_id, @admins, :id, :email, { include_blank: "Unassigned" }, class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2" %>
      </div>
      <%= form.submit "Save changes", class: "w-full rounded-md bg-teal-700 px-4 py-2 font-semibold text-white hover:bg-teal-800" %>
    <% end %>
  </aside>
</section>
