<!DOCTYPE html>
<html lang="en">
  <head>
    <title>CivicFlow</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-950">
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
        <%= link_to "CivicFlow", root_path, class: "text-xl font-semibold text-teal-800" %>
        <nav aria-label="Primary navigation" class="flex items-center gap-4 text-sm">
          <%= link_to "Submit request", new_issue_path, class: "font-medium text-slate-700 hover:text-teal-800" %>
          <% if user_signed_in? && current_user.admin? %>
            <%= link_to "Admin", admin_root_path, class: "font-medium text-slate-700 hover:text-teal-800" %>
          <% end %>
          <% if user_signed_in? %>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "rounded-md bg-slate-900 px-3 py-2 font-medium text-white hover:bg-slate-700" %>
          <% else %>
            <%= link_to "Admin sign in", new_user_session_path, class: "rounded-md bg-teal-700 px-3 py-2 font-medium text-white hover:bg-teal-800" %>
          <% end %>
        </nav>
      </div>
    </header>

    <main id="main" class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <% if notice.present? %>
        <p class="mb-6 rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-900" role="status"><%= notice %></p>
      <% end %>
      <% if alert.present? %>
        <p class="mb-6 rounded-md border border-rose-200 bg-rose-50 px-4 py-3 text-rose-900" role="alert"><%= alert %></p>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
