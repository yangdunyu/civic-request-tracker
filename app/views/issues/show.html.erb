<section class="max-w-3xl rounded-lg border border-slate-200 bg-white p-6">
  <p class="text-sm font-semibold uppercase tracking-wide text-teal-700">Request received</p>
  <h1 class="mt-2 text-3xl font-bold"><%= @issue.title %></h1>

  <dl class="mt-6 grid gap-4 sm:grid-cols-2">
    <div>
      <dt class="text-sm font-medium text-slate-500">Status</dt>
      <dd class="mt-1 font-semibold text-slate-950"><%= @issue.status_label %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-slate-500">Category</dt>
      <dd class="mt-1 font-semibold text-slate-950"><%= @issue.category_label %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-slate-500">Location</dt>
      <dd class="mt-1 font-semibold text-slate-950"><%= @issue.location %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-slate-500">Reference</dt>
      <dd class="mt-1 font-semibold text-slate-950">#<%= @issue.id %></dd>
    </div>
  </dl>

  <div class="mt-6 border-t border-slate-200 pt-6">
    <h2 class="font-semibold">Description</h2>
    <p class="mt-2 whitespace-pre-line text-slate-700"><%= @issue.description %></p>
  </div>
</section>
